{
  "name": "react-nested-markdown",
  "version": "0.1.0",
  "description": "React renderer for extended markdown with inline nested markdown blocks.",
  "keywords": [
    "react",
    "markdown",
    "react-markdown",
    "remark-gfm",
    "rehype",
    "nested-markdown",
    "inline-md",
    "renderer"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/react-nested-markdown.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/react-nested-markdown/issues"
  },
  "homepage": "https://github.com/your-org/react-nested-markdown#readme",
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --external react,react-dom,@mui/material,@emotion/react,@emotion/styled,antd",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "@mui/material": ">=5.0.0",
    "@emotion/react": ">=11.0.0",
    "@emotion/styled": ">=11.0.0",
    "antd": ">=5.0.0"
  },
  "dependencies": {
    "marked": "^12.0.0",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0",
    "rehype-raw": "^6.0.0",
    "rehype-sanitize": "^6.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0"
  }
}
